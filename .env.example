# NOTE: The Streamlit app does NOT read this .env file (there is no python-dotenv).
# App code uses st.secrets -> copy these values into .streamlit/secrets.toml (TOML syntax,
# values quoted), or into the Secrets UI on Streamlit Community Cloud. See README.md.
#
# admin.py and assessor/openai_assessor.py read OPENAI_API_KEY from the OS environment,
# so also export that in your shell when running those.

OPENAI_API_KEY=put_your_openai_api_key_here

# Read by base.py but not actually used to connect; the user is part of the connection string.
MONGODB_USERNAME=put_your_mongodb_username_here

MONGODB_PASSWORD=put_your_mongodb_password_here

MONGODB_CONNECTION_STRING=put_your_mongodb_connection_string_here

# Database the app reads/writes (collections: modules_live, users, user_module_progress).
# Warning: scripts/update_module_data.py and scripts/load_data.py currently hard-code 'funce_db'
# instead of using this value - fix them before seeding data.
MONGODB_DATABASE_NAME=prq_bot
